        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "SWITCH(\n    {fldOTjPqy7cVjmJ42} & \"-\" & {fldktzcwDudNfkOOg},\n\n    \"Product Owner-Client\", \n    SWITCH(\n        {fldKma57tUlyzIFTJ},\n        1, \"The Product Owner frequently demonstrates poor understanding and pronunciation of English, leading to significant communication issues.\",\n        2, \"The Product Owner often struggles with understanding and pronouncing English, causing frequent misunderstandings.\",\n        3, \"The Product Owner occasionally has difficulties with English understanding and pronunciation, impacting communication effectiveness.\",\n        4, \"The Product Owner has a basic understanding of English, but pronunciation inconsistencies affect clarity.\",\n        5, \"The Product Owner generally understands English well, but occasional pronunciation errors can cause minor communication gaps.\",\n        6, \"The Product Owner is proficient in understanding English and communicates clearly, though some pronunciation nuances could improve.\",\n        7, \"The Product Owner consistently understands and pronounces English accurately, facilitating effective communication.\",\n        8, \"The Product Owner has a strong command of English understanding and pronunciation, enhancing communication within the team.\",\n        9, \"The Product Owner demonstrates excellent understanding and pronunciation of English, ensuring clear and effective communication.\",\n        10, \"The Product Owner is a model of English proficiency, with exceptional understanding and pronunciation, ensuring flawless communication.\",\n        BLANK()\n    ),\n\n    \"Product Owner-Talent\", \n    SWITCH(\n        {fldKma57tUlyzIFTJ},\n        1, \"The talent frequently demonstrates poor understanding and pronunciation of English, leading to significant communication issues.\",\n        2, \"The talent often struggles with understanding and pronouncing English, causing frequent misunderstandings.\",\n        3, \"The talent occasionally ha