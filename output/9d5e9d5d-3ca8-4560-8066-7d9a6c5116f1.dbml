    {
      "id": "tblbdNRDIFwvq30Kj",
      "name": "QA Penalization Cycles",
      "primaryFieldId": "fldAt3DoxbbCFdpFL",
      "fields": [
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "CONCATENATE(\n    \"QA-\", \n    IF({fldQht4cPBRuGjykw}, {fldQht4cPBRuGjykw}, 0), \n    \"-PEN-\", \n    IF({fldbAJO3JlorPYY9k}, {fldbAJO3JlorPYY9k}, 0)\n)",
            "referencedFieldIds": [
              "fldQht4cPBRuGjykw",
              "fldbAJO3JlorPYY9k"
            ],
            "result": {
              "type": "singleLineText"
            }
          },
          "id": "fldAt3DoxbbCFdpFL",
          "name": "ID",
          "description": "ID formula field that always starts with QA and has the Max Cycle Correction and Penalization Cost in the formula."
        },
        {
          "type": "percent",
          "options": {
            "precision": 2
          },
          "id": "fldbAJO3JlorPYY9k",
          "name": "Penalization Cost",
          "description": "Field to store the cost to SPs for the QA Penalization Cycle."
        },
        {
          "type": "number",
          "options": {
            "precision": 0
          },
          "id": "fldQht4cPBRuGjykw",
          "name": "Max Cycle Corrections",
          "description": "Maximum threshold for correction cycles for the QA Penalization."
        },
        {
          "type": "createdTime",
          "options": {
            "result": {
              "type": "dateTime",
              "options": {
                "dateFormat": {
                  "name": "local",
                  "format": "l"
                },
                "timeFormat": {
                  "name": "12hour",
                  "format": "h:mma"
                },
                "timeZone": "America/Guatemala"
              }
            }
          },
