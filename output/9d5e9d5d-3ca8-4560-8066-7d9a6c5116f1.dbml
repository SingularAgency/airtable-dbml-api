        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "IF(\n  MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}) = {fldmtuL0qvQcHViJz},\n  IF(\n    {fldp8FwGfzkUQPnAd} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n    IF(\n      {fldU4HGg1bLC67RT1} = MAX({fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n      'Credibility',\n      IF(\n        {fldgt49U5HNG5OayB} = MAX({fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n        'Reliability',\n        'Group Thinking'\n      )\n    ),\n    IF(\n      {fldU4HGg1bLC67RT1} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n      IF(\n        {fldp8FwGfzkUQPnAd} = MAX({fldp8FwGfzkUQPnAd}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n        'Intimacy',\n        IF(\n          {fldgt49U5HNG5OayB} = MAX({fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n          'Reliability',\n          'Group Thinking'\n        )\n      ),\n      IF(\n        {fldgt49U5HNG5OayB} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n        IF(\n          {fldp8FwGfzkUQPnAd} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldxKHS7ViVXx0Of0}),\n          'Intimacy',\n          IF(\n            {fldU4HGg1bLC67RT1} = MAX({fldU4HGg1bLC67RT1}, {fldxKHS7ViVXx0Of0}),\n            'Credibility',\n            'Group Thinking'\n          )\n        ),\n        IF(\n          {fldxKHS7ViVXx0Of0} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n          IF(\n            {fldp8FwGfzkUQPnAd} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}),\n            'Intimacy',\n            IF(\n              {fldU4HGg1bLC67RT1} = MAX({fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}),\n              'Credibility',\n              'Reliability'\n            )\n          ),\n          \"\"\n        )\n      )\n    )\n  ),\n  IF(\n    {fldp8FwGfzkUQPnAd} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n    'Intimacy',\n    IF(\n      {fldU4HGg1bLC67RT1} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n      'Credibility',\n      IF(\n        {fldgt49U5HNG5OayB} = MAX({fldp8FwGfzkUQPnAd}, {fldU4HGg1bLC67RT1}, {fldgt49U5HNG5OayB}, {fldxKHS7ViVXx0Of0}),\n        'Reliability',\n        'Group Thinking'\n      )\n    )\n  )\n)",
