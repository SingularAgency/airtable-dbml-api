          "options": {
            "isValid": true,
            "formula": "SWITCH(\n  {fldveMqqKA0orWBbj},\n  1, \"Poor: Reliability is extremely low, with little or no evidence of commitment fulfillment.\",\n  2, \"Very Low: Reliability is very low, with serious deficiencies in meeting commitments.\",\n  3, \"Low: Reliability is low, with noticeable inconsistencies in meeting commitments.\",\n  4, \"Below Average: Reliability is moderately low, with key areas needing substantial improvement.\",\n  5, \"Average: Reliability is acceptable, with room for improvement but with a generally consistent commitment fulfillment.\",\n  6, \"Satisfactory: Reliability is moderate, with solid aspects and some areas for refinement.\",\n  7, \"Moderately High: Reliability is good, with overall solid performance in commitment fulfillment.\",\n  8, \"High: Reliability is very good, exceeding expectations in various aspects.\",\n  9, \"Very High: Reliability is excellent, demonstrating a high level of consistent commitment fulfillment.\",\n  10, \"Outstanding: Reliability is exceptional, with an extraordinary level of consistency and commitment fulfillment.\",\n  \"The score is out of range or not a number\"\n)",
