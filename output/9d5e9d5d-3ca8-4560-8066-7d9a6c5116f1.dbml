        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "IF(\n  {fldsJ0vykeUkOzcoc} = MAX({fldsJ0vykeUkOzcoc}, {fldxA8Lo3zFv6v0FE}, {fldAcQgirjhrIbv7u}, {fldDMAilqm6TNVg0c}),\n  \"Intimacy\",\n  IF(\n    {fldxA8Lo3zFv6v0FE} = MAX({fldsJ0vykeUkOzcoc}, {fldxA8Lo3zFv6v0FE}, {fldAcQgirjhrIbv7u}, {fldDMAilqm6TNVg0c}),\n    \"Credibility\",\n    IF(\n      {fldAcQgirjhrIbv7u} = MAX({fldsJ0vykeUkOzcoc}, {fldxA8Lo3zFv6v0FE}, {fldAcQgirjhrIbv7u}, {fldDMAilqm6TNVg0c}),\n      \"Reliability\",\n      \"Group Thinking\"\n    )\n  )\n)",
