    {
      "id": "tblpOKAGM4x8P3Usu",
      "name": "AI calification",
      "primaryFieldId": "fldM095zaSigUWXbg",
      "fields": [
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldM095zaSigUWXbg",
          "name": "Calificacion"
        },
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldTeHK6OUxdnGnOZ",
          "name": "Impacto Estratégico",
          "description": "Evalúe si la implementación de IA genera un cambio significativo en la organización o el cliente y si aporta ventajas competitivas sostenibles."
        },
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldqS8eXPaKNCiJEl",
          "name": "Escalabilidad y Adaptabilidad",
          "description": "Determine si la solución puede ampliarse a diferentes contextos o volúmenes sin pérdida de eficacia."
        },
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldlGSHOa8YEFd50L",
          "name": "Originalidad Técnica",
          "description": "Considere si la solución utiliza enfoques de IA innovadores o avanzados.\nEvalúe la novedad de la implementación en el contexto de su aplicación."
        },
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldxMXavHspR4RsSE",
          "name": "ROI",
          "description": "Analice si el impacto generado (ahorros, ingresos, tiempo) justifica los costos de implementación.\nIncluya métricas cuantificables, si están disponibles."
        },
        {
          "type": "number",
          "options": {
            "precision": 1
          },
          "id": "fldgB753cE2yHknXR",
          "name": "Eficiencia en la Optimización",
          "description": "Analice si la implementación reduce significativamente recursos, tiempo o errores en los procesos internos."
        },
        {
          "type": "multilineText",
          "id": "fldC2kX4PpsmpKpR7",
          "name": "Recomendación final"
        },
        {
          "type": "formula",
