        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "SWITCH(\n  {fldr8BryJbVPROFuH},\n  0, \"Deficient (Poor): Credibility is virtually non-existent, without a basis or evidence of trust.\",\n  1, \"Deficient (Poor): Credibility is virtually non-existent, without a basis or evidence of trust.\",\n  2, \"Very Low: Significant deficiencies in credibility are perceived; there is little evidence of trust.\",\n  3, \"Low: Credibility is minimal, with critical areas that need improvement.\",\n  4, \"Below Average: Credibility is low, with notable deficiencies and key areas requiring attention.\",\n  5, \"Average: Credibility is acceptable, with room for improvement but with a solid foundation.\",\n  6, \"Satisfactory: Credibility is moderate, with solid aspects and some areas for refinement.\",\n  7, \"Moderadamente Alto (Moderately High): Credibility is good, with overall solid performance.\",\n  8, \"High: Credibility is very good, exceeding expectations in various aspects.\",\n  9, \"Very High: Credibility is excellent, demonstrating a high level of confidence.\",\n  10, \"Outstanding: Credibility is exceptional, with an extraordinary level of confidence in skills related to assigned tasks.\",\n  \"The score is out of range or not a number\"\n)",
