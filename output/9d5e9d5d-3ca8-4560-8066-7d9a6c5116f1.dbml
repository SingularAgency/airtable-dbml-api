            "formula": "DATETIME_DIFF(\r\n  DATEADD(\r\n    DATETIME_PARSE(\r\n      IF(\r\n        MONTH({fldgjkQM5hLVDQGTi}) <= 3, \"Q1\",\r\n        IF(\r\n          MONTH({fldgjkQM5hLVDQGTi}) <= 6, \"Q2\",\r\n          IF(\r\n            MONTH({fldgjkQM5hLVDQGTi}) <= 9, \"Q3\", \"Q4\"\r\n          )\r\n        )\r\n      ) & \" \" & YEAR({fldgjkQM5hLVDQGTi}), 'Q MMM YYYY'\r\n    ), 0, 'quarter'\r\n  ),\r\n  DATEADD(\r\n    DATETIME_PARSE(\r\n      IF(\r\n        MONTH(TODAY()) <= 3, \"Q1\",\r\n        IF(\r\n          MONTH(TODAY()) <= 6, \"Q2\",\r\n          IF(\r\n            MONTH(TODAY()) <= 9, \"Q3\", \"Q4\"\r\n          )\r\n        )\r\n      ) & \" \" & YEAR(TODAY()), 'Q MMM YYYY'\r\n    ), 0, 'quarter'\r\n  ),\r\n  'quarter'\r\n)\r\n",
