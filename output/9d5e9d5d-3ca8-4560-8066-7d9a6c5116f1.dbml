        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "\n\nIF(\n  {fldktzcwDudNfkOOg} = \"Client\", \n  SWITCH(\n    {fldXXmlSs9zvUHPle},\n    1, \"Poor: Intimacy is deficient. The client shows a complete lack of openness and communication, greatly hindering the creation of an effective relationship with our team.\",\n    2, \"Very Low: Intimacy is very low. The client offers very little openness and communication, resulting in a very superficial and ineffective relationship with our team.\",\n    3, \"Low: Intimacy is low. The client shows some openness and communication, but it is insufficient to establish an effective and meaningful relationship with our team.\",\n    4, \"Below Average: Intimacy is below average. Although the client provides some openness and communication, it is not consistent or deep enough to significantly improve the relationship with our team.\",\n    5, \"Average: Intimacy is average. The client offers a moderate level of openness and communication, modestly contributing to the creation of an effective relationship with our team.\",\n    6, \"Satisfactory: Intimacy is satisfactory. The client shows an acceptable level of openness and communication, helping to establish an effective and collaborative relationship with our team.\",\n    7, \"Moderately High: Intimacy is moderately high. The client offers a notable level of openness and communication, greatly contributing to the creation of a solid and productive relationship with our team.\",\n    8, \"High: Intimacy is high. The client shows great openness and communication, facilitating the creation of a very effective and trustful relationship with our team.\",\n    9, \"Very High: Intimacy is very high. The client provides an exceptional level of openness and communication, resulting in a deeply connected and collaborative relationship with our team.\",\n    10, \"Outstanding: Intimacy is outstanding. The client goes above and beyond by demonstrating exceptional openness and communication, establishing an exceptionally strong and trustful relationship with our team.\",\n    BLANK()\n  ), \n  IF(\n    {fldXXmlSs9zvUHPle} = BLANK(), \n    BLANK(),\n    SWITCH(\n      {fldXXmlSs9zvUHPle},\n      1, \"Does not demonstrate the ability to understand or connect with the client.\",\n      2, \"Minimum understanding and superficial connection with the client.\",\n      3, \"Basic understanding and limited emotional connection.\",\n      4, \"Moderate understanding and occasional empathetic connection.\",\n      5, \"Clear understanding and regular empathetic, trustworthy relationship.\",\n      6, \"Solid understanding and frequent close, trusting relationship.\",\n      7, \"Strong: Good understanding and consistent close, empathetic connection.\",\n      8, \"Very good: Deep understanding and frequent empathetic, trustworthy relationship.\",\n      9, \"Excellent: Exceptional understanding and deep, empathetic trust-based relationships.\",\n      10, \"Exceptional: Outstanding understanding and authentic, lasting emotional connection.\"\n    )\n  )\n)",
