        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld4fCmQFP1Q1IENN"
            ],
            "prompt": [
              "Given the following Project Brief Summary from the client, as a Mckinsey senior consultant, please suggest appropriate SMART strategic business objectives that a Product Owner should suggest in the pursuit of generetaing bussiess value and ROI.\n\nProject Brief Summary:\n",
              {
                "field": {
                  "fieldId": "fld4fCmQFP1Q1IENN"
                }
              },
              "\n"
            ]
          },
          "id": "fld01H7PGhgjaANKJ",
          "name": "Business Objectives"
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld4fCmQFP1Q1IENN",
              "fld01H7PGhgjaANKJ",
              "fldOFv4fYl7UCtwno"
            ],
            "prompt": [
              "As a Mckinsey senior consultant, given the Project Brief Summary, the listed business objectives, and the summary of the las user stories worked on the the project, please suggest 25 new functionalities in the form of user stories that could deliver significant business value and ROI.\n\nProject Brief Summary:\n",
              {
                "field": {
                  "fieldId": "fld4fCmQFP1Q1IENN"
                }
              },
              "\n\nBusiness Objectives:\n",
              {
