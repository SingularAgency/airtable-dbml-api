          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "IF(\n  {fldktzcwDudNfkOOg} = \"Client\", \n  'How would you rate the client\\'s openness to collaborate and positively receive value propositions offered to them, as well as actively engage in discussions to enhance the project\\'s success?', \n  IF(\n    {fldktzcwDudNfkOOg} = BLANK(), \n    BLANK(), \n    'Does the talent collaborate with the team and prioritize collective interests over individual ones?'\n  )\n)",
