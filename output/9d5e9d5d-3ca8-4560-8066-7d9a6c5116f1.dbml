          "name": "BuildSummary_prompt"
        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "\"Summarize in a brief executive summary what Singular delivered on the Sprint based on the following Stories and list potential KPIs that were impacted in a professional, technical tone:\\n\\n\" &\r\n\"{Stories}\\n\\n\" &\r\n\"Try to use technical language but explaining simply the benefit.\\n\\n\" &\r\n\"Please not use markdown format in the text result. Focus on story telling, impact based, executive summary, use bullets and leave admin tasks last, and name that category: Administrative Support. Add details about \" & {fldJI7UdzncMXrgDP} & \". Use bullets but use the content in a story telling framework.\\n\\n\" &\r\n\"It is critical that you try to categorize by story type or benefit.\"\r\n",
            "referencedFieldIds": [
              "fldJI7UdzncMXrgDP"
            ],
            "result": {
              "type": "singleLineText"
            }
