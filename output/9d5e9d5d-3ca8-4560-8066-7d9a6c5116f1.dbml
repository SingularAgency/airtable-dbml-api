            "formula": "IF(\n    LEN({fldYmIigDe8SU6sQO} & \"\") = 0,\n    \"\",\n    IF(\n        {fldYmIigDe8SU6sQO} * 100 < 20, \n        \"Desarrollo de Confianza Inicial\",\n        IF(\n            AND(\n                {fldYmIigDe8SU6sQO} * 100 >= 20, \n                {fldYmIigDe8SU6sQO} * 100 < 40\n            ), \n            \"Confianza Básica\",\n            IF(\n                AND(\n                    {fldYmIigDe8SU6sQO} * 100 >= 40, \n                    {fldYmIigDe8SU6sQO} * 100 < 60\n                ), \n                \"Confianza Moderada\",\n                IF(\n                    AND(\n                        {fldYmIigDe8SU6sQO} * 100 >= 60, \n                        {fldYmIigDe8SU6sQO} * 100 < 80\n                    ), \n                    \"Alta Confianza\",\n                    \"Excelencia en Confianza\"\n                )\n            )\n        )\n    )\n)",
