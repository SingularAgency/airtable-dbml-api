        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "DATETIME_DIFF(\n  DATEADD(\n    DATETIME_PARSE(\n      IF(\n        MONTH({fldAkT43u5ZTTDBTI}) <= 3, \"Q1\",\n        IF(\n          MONTH({fldAkT43u5ZTTDBTI}) <= 6, \"Q2\",\n          IF(\n            MONTH({fldAkT43u5ZTTDBTI}) <= 9, \"Q3\", \"Q4\"\n          )\n        )\n      ) & \" \" & YEAR({fldAkT43u5ZTTDBTI}), 'Q MMM YYYY'\n    ), 0, 'quarter'\n  ),\n  DATEADD(\n    DATETIME_PARSE(\n      IF(\n        MONTH(TODAY()) <= 3, \"Q1\",\n        IF(\n          MONTH(TODAY()) <= 6, \"Q2\",\n          IF(\n            MONTH(TODAY()) <= 9, \"Q3\", \"Q4\"\n          )\n        )\n      ) & \" \" & YEAR(TODAY()), 'Q MMM YYYY'\n    ), 0, 'quarter'\n  ),\n  'quarter'\n)\n",
            "referencedFieldIds": [
              "fldAkT43u5ZTTDBTI"
            ],
            "result": {
              "type": "number",
              "options": {
                "precision": 0
              }
            }
          },
