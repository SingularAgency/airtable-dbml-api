        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "IF(\n    {fldGp9lqY1canp6XJ} = \"Accepted by Client\",\n    \"Story has been delivered\",\n    IF(\n        WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) < 0,\n        \"Overdue by \" & IF(\n            WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) <= -2,\n            WORKDAY_DIFF({fldvOVPOPP3GMKyMd}, NOW()) - 1,\n            WORKDAY_DIFF({fldvOVPOPP3GMKyMd}, NOW())\n        ) & \" days 🔴\",\n        IF(\n            WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) = 1,\n            \"Due today!⚠️\",\n            IF(\n                WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) = 2,\n                \"Due tomorrow!⚠️\",\n                IF(\n                    WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) >= 7,\n                    \"Due in \" & ROUND(WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) / 7, 0) & \" weeks 🟢\",\n                    IF(\n                        WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) >= 30,\n                        \"Overdue by 💀\" & ROUND(WORKDAY_DIFF(NOW(), {fldvOVPOPP3GMKyMd}) / 30, 0) & \" months\",\n                        \"Due in \" & DATETIME_DIFF(DATEADD({fldvOVPOPP3GMKyMd}, 1, \"day\"), NOW(), \"days\") & \" days 🟢\"\n                    )\n                )\n            )\n        )\n    )\n)\n",
            "referencedFieldIds": [
              "fldGp9lqY1canp6XJ",
