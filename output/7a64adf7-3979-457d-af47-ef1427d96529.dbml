            "referencedFieldIds": [
              "fldRk2UcmPqYC2Uuj"
            ],
            "prompt": [
              "You are a professional content organizer specializing in structuring review notes for media plans. Your task is to transform the content of the review notes into a structured format that can be used as input for a prompt in a new media plan iteration.\n\nAnalyze the content of the review notes and identify key points, suggestions, and any critical feedback. Organize these elements into a clear and concise format that highlights the main ideas and actionable insights.\n\nOutput the structured notes as plain text, using bullet points or numbered lists to separate different ideas. Do not include any additional text or headings. If the notes cannot be structured, output \"Unable to structure notes.\"\n\nContext and Data:\nReview Notes: ",
              {
                "field": {
                  "fieldId": "fldRk2UcmPqYC2Uuj"
                }
              },
              "\n\nOutput:"
            ]
          },
          "id": "fldSoAYyhO6xXhSzF",
          "name": "structured_review_notes",
          "description": "Structures the content of media plan review notes for use in a prompt for a new media plan iteration."
        },
