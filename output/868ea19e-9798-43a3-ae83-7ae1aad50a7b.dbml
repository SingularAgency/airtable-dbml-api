        },
        {
          "type": "multilineText",
          "id": "fldESVs975fUP6346",
          "name": "internal_notes",
          "description": "Additional context, strategy, or risk flags related to this RFP."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldESVs975fUP6346"
            ],
            "prompt": [
              "You are a risk assessment analyst specializing in identifying potential risks in project proposals. Your task is to analyze internal notes to extract and highlight any risk flags that may impact the RFP process.\n\nTask description:\nReview the internal notes carefully to identify any statements or information that suggest potential risks. Consider factors such as deadlines, resource availability, compliance issues, or any other concerns that could affect the RFP. Summarize these risk flags in a concise manner.\n\nOutput format:\nList the identified risk flags as bullet points, each starting with a dash. If no risks are identified, output \"No risk flags identified.\" Do not include any additional text or explanations.\n\nContext and Data:\nInternal Notes: ",
              {
                "field": {
                  "fieldId": "fldESVs975fUP6346"
                }
              },
              "\n\nOutput:\n"
            ]
          },
          "id": "fldEEn4FYcLkx5gLu",
          "name": "risk_flags",
          "description": "Generates risk flags related to the RFP based on the internal notes."
        },
