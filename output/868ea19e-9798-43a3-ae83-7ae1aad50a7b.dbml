        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldoUfdNOKvKlI6Ww",
              "fldZE8C6lsxeHQy6c"
            ],
            "prompt": [
              "You are a data extraction specialist tasked with extracting specific information from RFP documents and supplementing missing details with internet research.\n\nExtract the following information from the RFP base attachment: Title and Number of RFP, Name of School District, City, State, District Size, Number of Students, Number of Schools, Size (categorized as Small, Medium, Large), State Level, Individual School, RFP Due Date with Time Zone, Q&A Due Date with Time Zone, Term of Contract, Reference Requirements, and Keywords. If any information is missing, search the internet to find it and include the source of the information. Only execute this task if the status is 'Yes'.\n\nOutput the extracted and supplemented information as a JSON object with key:value pairs. Ensure the JSON is concise and only includes the necessary information. If you cannot complete the request, output \"Unable to generate JSON.\" Do not include any additional text or formatting beyond the JSON structure.\n\nContext and Data:\nRFP Base: ",
              {
                "field": {
                  "fieldId": "fldoUfdNOKvKlI6Ww"
                }
              },
              "\nStatus: ",
              {
                "field": {
                  "fieldId": "fldZE8C6lsxeHQy6c"
                }
              },
              "\n\nOutput:"
            ]
          },
          "id": "fldg2S1jRAimCTSCL",
          "name": "rfp_info_extract",
          "description": "Generates a customized RFP document based on the RFP base, sales representative name, primary contact name, and deadline."
        },
