    company_name multilineText [note: 'business desc: Company name associated with the campaign., technical desc: Type: multilineText, field ID: fldOdcfdsDixT6anD']
    email email [note: 'business desc: Contact email for the client., technical desc: Type: email, field ID: fldyO7K6RioLNErDU']
    phone phoneNumber [note: 'business desc: Contact number for the client., technical desc: Type: phoneNumber, field ID: fld82RDbL0XUFW6LC']
