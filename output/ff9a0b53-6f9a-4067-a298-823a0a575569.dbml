Table advertisers {
    advertisers_identification formula [note: 'business desc: Unique identifier for advertisers. Stores alphanumeric codes., technical desc: Type: formula, field ID: fldbTyu46T58srV8v']
    company_name singleLineText [note: 'business desc: Name of the company the client represents., technical desc: Type: singleLineText, field ID: fldyNBA0trS3bgYQP']
    client_name singleLineText [note: 'business desc: Full name of the client., technical desc: Type: singleLineText, field ID: fldZVET5TuecVfHVr']
    email email [note: 'business desc: Contact email for the client., technical desc: Type: email, field ID: fldfAP3xT0WVtrgLO']
    phone phoneNumber [note: 'business desc: Contact phone number for the client., technical desc: Type: phoneNumber, field ID: fldGeQjk0iLMUPuWh']
    country singleSelect [note: 'business desc: Clients country of origin. Options: United States, technical desc: Type: singleSelect, Options: United States, field ID: fldEOvQb6ccY7psGz']
    state_province singleSelect [note: 'business desc: U.S. State of the client. Includes all 50 states., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld23R9uPQesuPBKj']
    city singleLineText [note: 'business desc: City where the client is based., technical desc: Type: singleLineText, field ID: fldcgcaHlUlkIlBah']
    website url [note: 'business desc: Website of the clients company, if available., technical desc: Type: url, field ID: fld7LJfC9F4IZoDQ5']
    record_id formula [note: 'business desc: System-generated unique identifier used for referencing this record across the platform and integrations., technical desc: Type: formula, field ID: fld7974ivOaW3eITT']
    created createdTime [note: 'business desc: Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking., technical desc: Type: createdTime, field ID: fldPOolk92JYqOkoF']
    last_modified lastModifiedTime [note: 'business desc: Timestamp that reflects the most recent update to the record, enabling version tracking and operational visibility., technical desc: Type: lastModifiedTime, field ID: fldGKvNSucdjQdBew']
    last_modified_by lastModifiedBy [note: 'business desc: Automatically records the user who made the most recent update to the client record. Useful for tracking collaboration and accountability., technical desc: Type: lastModifiedBy, field ID: fldsPr7goHTlblK7M']
    project_brief multipleRecordLinks [note: 'business desc: Connects projects to their detailed briefs, providing context., technical desc: Type: multipleRecordLinks, Reference to project_brief table, field ID: fldbokg9mWK3KVZS1']
    active_campaign multipleRecordLinks [note: 'business desc: This field connects orders to their associated active marketing campaign. Provides campaign tracking., technical desc: Type: multipleRecordLinks, Reference to active_campaign table, field ID: fldR9PHX7rz7DSVRW']
    first_strategic_insights multilineText [note: 'business desc: Initial strategic analysis findings. Stores key observations., technical desc: Type: multilineText, field ID: fldQQHCyyJIxfcJAr']
    jwt_anonymous multilineText [note: 'business desc: Token anonimo para validar cliente, technical desc: Type: multilineText, field ID: fld3sojpcNwAlccBU']
    autheinticated_account checkbox [note: 'business desc: Cuando el cliente ya es un usuario autenticado, technical desc: Type: checkbox, field ID: fldm08k8JbRe8Hx9z']
    id autoNumber [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fld6DwWfSijqwBcEO']
    project_brief_copy multipleRecordLinks [note: 'business desc: Connects project details to their test versions. Facilitates comparison and updates., technical desc: Type: multipleRecordLinks, Reference to project_brief_test table, field ID: fld9t0KJ4vNSGR0YP']
    note: '### advertisers Table (airtable id: tblchWDOuPzJczwMZ) - This table stores information about clients submitting campaign briefs, including their contact details and organizational context. It serves as a master registry to link client identity with submitted and approved campaign records across the CRM system.'
}

Table project_brief {
    project_brief_id formula [note: 'business desc: Unique identifier for each project brief, (autonumber + company name + created date) ., technical desc: Type: formula, field ID: fldd8EhKwRISulQMO']
