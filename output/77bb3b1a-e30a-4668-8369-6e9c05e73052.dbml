        },
        {
          "type": "multilineText",
          "id": "fldQMbKerfVodEFvJ",
          "name": "grassroots_media_campaign_finished_comments",
          "description": "Comments on completed grassroots media campaigns."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldQMbKerfVodEFvJ"
            ],
            "prompt": [
              "You are a professional business analyst specializing in crafting refined and professional comments from raw feedback. Your task is to analyze the provided comments and transform them into polished business statements.\n\nTask description:\nReview the raw comments provided and identify key insights, themes, and sentiments. Use this information to craft a concise and professional comment that reflects the overall tone and key points of the original feedback. Ensure the comment is suitable for a business context and maintains a professional tone throughout.\n\nOutput format:\nA single, polished business comment that captures the essence of the original feedback, formatted as plain text. Do not include any additional text or headings. If unable to generate a comment, output \"Unable to generate a professional comment from the provided feedback.\" Example: \"The campaign successfully met its objectives, demonstrating strong engagement and positive feedback from the target audience.\" (Real examples should be longer and more detailed based on the original comments.)\n\nContext and Data:\nComments: ",
              {
                "field": {
                  "fieldId": "fldQMbKerfVodEFvJ"
                }
              },
              "\n\nOutput:"
            ]
          },
          "id": "fldSB5eKdsJp8tKpW",
          "name": "professional_business_comments",
          "description": "Generates professional and business-oriented comments based on the campaign_finished_comments field."
        },
        {
          "type": "multilineText",
          "id": "fld0LLKqqKUEtpfyq",
          "name": "Advertiser_campaign_finished_comments",
          "description": "Comments on why an advertisers campaign ended."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld0LLKqqKUEtpfyq"
            ],
            "prompt": [
              "You are a data analyst specializing in evaluating marketing campaign feedback.\n\nTask description:\nAnalyze the comments provided by the advertiser in the ",
              {
                "field": {
                  "fieldId": "fld0LLKqqKUEtpfyq"
                }
              },
              " column to determine a feedback lift rating. Rate the feedback on a scale from 1 to 5, where 1 indicates very negative feedback and 5 indicates very positive feedback. Consider the tone, sentiment, and specific mentions of campaign success or issues.\n\nOutput format:\nOutput a single number between 1 and 5, representing the feedback lift rating. Do not include any additional text or explanation in the output. For example, \"3\".\n\nContext and Data:\nAdvertiser Comments: ",
              {
                "field": {
                  "fieldId": "fld0LLKqqKUEtpfyq"
                }
              },
              "\n\nOutput:\n"
            ]
          },
          "id": "fldEEwS4gXPfrthI2",
          "name": "advertiser_feedback_left_rating",
          "description": "Rates the feedback left for the advertiser based on their finished campaign comments on a scale from 1 to 5."
        },
        {
          "type": "singleSelect",
          "options": {
            "choices": [
              {
                "id": "selV5ex0ymoZVtU1P",
                "name": "Very Negative",
                "color": "blueLight2"
              },
              {
                "id": "selemXwsbYX4glCzZ",
                "name": "Negative",
                "color": "cyanLight2"
              },
              {
                "id": "selc0VLOKmK0o1k7p",
                "name": "Neutral",
                "color": "tealLight2"
              },
              {
                "id": "selFoldpezE4v81UI",
                "name": "Positive",
                "color": "greenLight2"
              },
              {
                "id": "selZdhDjYZ0q8eAcB",
                "name": "Very Positive",
                "color": "yellowLight2"
              }
            ]
          },
          "id": "fldB1NFneEmxEoWVG",
          "name": "Sentiment Analysis Tag",
          "description": "Tags the advertiser feedback lift rating with sentiment analysis words ranging from 'Very Negative' to 'Very Positive'."
        },
