        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldGxH03VcRG0dcms"
            ],
            "prompt": [
              "You are a text extraction specialist focusing on identifying specific sections within a document.\n\nYour task is to extract the 'Campaign Planning Prompt' and  'Calls to Action' description from the provided text. This description is located towards the end of the text. Output the extracted description in a key:value JSON format, where 'Campaign Planning Prompt' is the key and the extracted text is the value and 'Calls to Action' is the key and the extracted text is the value as well. If the description cannot be found, output \"Description not found.\"\n\nContext and Data:\nAI Review Notes: ",
              {
                "field": {
                  "fieldId": "fldGxH03VcRG0dcms"
                }
              },
              "\n\nOutput:\n"
            ]
