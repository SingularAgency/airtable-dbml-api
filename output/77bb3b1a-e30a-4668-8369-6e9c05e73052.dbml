    {
      "id": "tblkmpqL98s7MydEh",
      "name": "project_brief",
      "description": "This table consolidates all necessary data for evaluating and processing campaign briefs submitted by clients. It includes contact information, campaign details, target demographics, media preferences, geography targeting, and workflow status. This structure ensures standardized data collection, review, and collaboration for streamlined campaign approval   and execution workflows within the Grassroots CRM platform.",
      "primaryFieldId": "fldd8EhKwRISulQMO",
      "fields": [
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "\"#PB\"&\r\nREPT(\"0\",6-LEN(CONCATENATE({fldgoRDCTyjheljsZ})))&{fldgoRDCTyjheljsZ}&\" - \"&{fldOdcfdsDixT6anD}&\" - \"&DATETIME_FORMAT({fld1zjTrLvhT86dVi},\"YYYY/MM/DD\")",
            "referencedFieldIds": [
              "fldgoRDCTyjheljsZ",
              "fldOdcfdsDixT6anD",
              "fld1zjTrLvhT86dVi"
            ],
            "result": {
              "type": "singleLineText"
            }
          },
          "id": "fldd8EhKwRISulQMO",
          "name": "project_brief_id",
          "description": "Unique identifier for each project brief, (autonumber + company name + created date) ."
        },
        {
