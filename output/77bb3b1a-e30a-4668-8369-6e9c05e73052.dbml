        {
          "type": "number",
          "options": {
            "precision": 2
          },
          "id": "fldDXcLNEbgMiyMag",
          "name": "commission_percentage_number"
        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "(({fldDXcLNEbgMiyMag})/100) * {fldkR1adM2ETcjGIQ}",
            "referencedFieldIds": [
              "fldDXcLNEbgMiyMag",
              "fldkR1adM2ETcjGIQ"
            ],
            "result": {
              "type": "currency",
              "options": {
                "precision": 2,
                "symbol": "$"
              }
            }
          },
          "id": "fldblZ1gYnkwfqjy1",
