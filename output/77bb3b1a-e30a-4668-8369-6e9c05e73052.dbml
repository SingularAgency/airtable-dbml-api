        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "{fldkR1adM2ETcjGIQ} * (1 - ({fldDXcLNEbgMiyMag}/100))\r\n",
            "referencedFieldIds": [
              "fldkR1adM2ETcjGIQ",
              "fldDXcLNEbgMiyMag"
            ],
            "result": {
              "type": "currency",
              "options": {
                "precision": 2,
