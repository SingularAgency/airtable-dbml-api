        {
          "type": "multilineText",
          "id": "fld0Ik8ARUkZqMghd",
          "name": "rate_analysis",
          "description": "Analysis of rates, e.g., pricing, interest, or fees."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld0Ik8ARUkZqMghd"
            ],
            "prompt": [
              "You are a content transformer specializing in converting technical analysis into user-friendly text. Your task is to take complex rate analysis data and present it in a way that is easy to understand for a general audience.\n\nReview the rate analysis data provided. If the data is not empty, summarize the key points and insights in a clear and concise manner, avoiding technical jargon and focusing on the main takeaways. If there is detailed data, present this detail in an outlet format after the friendly description.\n\nOutput format: A plain text summary of the rate analysis, written in simple language, followed by a table format of the detailed data if available. If the rate analysis is empty, output \"No rate analysis available.\" Do not include any additional text or headings. Example: \"The rate analysis indicates a stable trend with minor fluctuations over the past quarter.\"\n\nContext and Data:\nRate Analysis: ",
              {
                "field": {
                  "fieldId": "fld0Ik8ARUkZqMghd"
                }
              },
              "\n\nOutput:\none-shot example:\n\"Banner Homepage Rate: 5\nNative Homepage Rate: 5\nCalculation Reference: 5x Banner Homepage ($5555) + 5x Native Homepage ($10000) = $15555\"\n"
            ]
          },
          "id": "fldpeofTZk0EpRNaQ",
          "name": "rate_analysis_summary",
          "description": "Converts the rate analysis data into YAML format if it is not empty."
        },
        {
          "type": "autoNumber",
          "id": "fldl9CbUymbI0fYHW",
          "name": "id",
          "description": "Unique identifier for each record. Integer value."
        }
