Table project_brief {
    project_brief_id varchar [note: 'business desc: Unique identifier for each project brief, (autonumber + company name + created date) ., technical desc: Type: formula, field ID: fldd8EhKwRISulQMO']
    client_name text [note: 'business desc: Name of the client submitting the brief., technical desc: Type: multilineText, field ID: fldpWTAo3v2vtznYX']
    record_id varchar [note: 'business desc: System-generated unique identifier used for referencing this record across the platform and integrations., technical desc: Type: formula, field ID: fldb37QIeICev3hBy']
    company_name text [note: 'business desc: Company name associated with the campaign., technical desc: Type: multilineText, field ID: fldOdcfdsDixT6anD']
    email varchar [note: 'business desc: Contact email for the client., technical desc: Type: email, field ID: fldyO7K6RioLNErDU']
    phone varchar [note: 'business desc: Contact number for the client., technical desc: Type: phoneNumber, field ID: fld82RDbL0XUFW6LC']
    country varchar [note: 'business desc: Country of origin for the campaign. Options: United States., technical desc: Type: singleSelect, Options: United States, field ID: fldQ1Zg2RUV9kOYCM']
    state_province varchar [note: 'business desc: U.S. state or province of the client. Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld4DMGJCCrSWKUkR']
    city text [note: 'business desc: City where the client is located., technical desc: Type: multilineText, field ID: fld5thsP74HlOEFHf']
    website varchar [note: 'business desc: Optional website link provided by the client., technical desc: Type: url, field ID: fldBqgWxlsN1Y3gsy']
    campaign_title text [note: 'business desc: Name/title of the campaign., technical desc: Type: multilineText, field ID: fldDMrRgz0Ihg58br']
    primary_objective text [note: 'business desc: Primary goal or objective of the campaign., technical desc: Type: multilineText, field ID: fld8ZFCdfHHRfmBm6']
    budget decimal [note: 'business desc: Estimated campaign budget in USD., technical desc: Type: currency, Precision: 2, Symbol: $, field ID: fldkR1adM2ETcjGIQ']
    start_date date [note: 'business desc: Planned start date of the campaign., technical desc: Type: date, Format: YYYY-MM-DD, field ID: fldplbOOkinzWAbfO']
    end_date date [note: 'business desc: Planned end date of the campaign., technical desc: Type: date, Format: YYYY-MM-DD, field ID: fldQ3CDax6MO4xViW']
    age_range_min float [note: 'business desc: Minimum age of the campaign target audience., technical desc: Type: number, field ID: fldOPc7TaJVKjkZbu']
    age_range_max float [note: 'business desc: Maximum age of the campaign target audience., technical desc: Type: number, field ID: fldq0wvsziVXD891Y']
    target_geography_state varchar [note: 'business desc: U.S. state targeted by the campaign. Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld1YJeEfDgUKlU9e']
    target_geography_city text [note: 'business desc: City targeted by the campaign., technical desc: Type: multilineText, field ID: fldwZmKKwYJP467J3']
    target_communities varchar [note: 'business desc: Demographic communities targeted by the campaign. Options: African American, Caribbean, Arab, East Asian, U.S. Indigenous, Indian American, Latino/Hispanic, Russian, South Asian, Southeast Asian, Jewish, Pacific Islander, East Slavic, West European, West African, Other., technical desc: Type: multipleSelects, Options: African American, Caribbean, Arab, East Asian, U.S. Indigenous, Indian American, Latino/Hispanic Russian, South Asian, Southeast Asian, Jewish, Pacific Islander, East Slavic, West European, West African, Other, Russian, Latino/Hispanic, field ID: fldpACPXF0jVRlEKR']
    preferred_media_placements varchar [note: 'business desc: Types of media preferred for ad placement. Options: Digital, Print, Radio, TV, Unconventional, Other., technical desc: Type: multipleSelects, Options: Digital, Print, Radio, TV, Unconventional, Other, field ID: fldOeMTg5OeQH7UCQ']
    target_audience_details text [note: 'business desc: Additional details about audience demographics or behaviors., technical desc: Type: multilineText, field ID: fldopT6JQbKMWOopp']
    uploaded_documents varchar [note: 'business desc: Supporting files for the campaign brief., technical desc: Type: multipleAttachments, field ID: fldhmFcXIAT0GaZsv']
    status varchar [note: 'business desc: Current review status (Options: Pending Review, Approved, Rejected)., technical desc: Type: singleSelect, Options: Pending Review, Approved, Rejected, field ID: fldv6J8hLAFYs86lx']
    review_notes text [note: 'business desc: Internal notes added by reviewer., technical desc: Type: richText, field ID: fldUCwNbON6q9J5qj']
    use_digital boolean [note: 'business desc: Indicates whether the campaign intends to use Digital media., technical desc: Type: checkbox, field ID: fldY0c3snhZkTJg9m']
    use_tv boolean [note: 'business desc: Indicates whether the campaign intends to use TV media., technical desc: Type: checkbox, field ID: fldYFhulETK12NIcO']
    use_radio boolean [note: 'business desc: Indicates whether the campaign intends to use Radio media., technical desc: Type: checkbox, field ID: fldBwaNwZ2u4Gc7Q8']
    use_print boolean [note: 'business desc: Indicates whether the campaign intends to use Print media., technical desc: Type: checkbox, field ID: fldDBrFY6Gbth8ysF']
    use_unconventional boolean [note: 'business desc: Indicates whether the campaign intends to use Unconventional media., technical desc: Type: checkbox, field ID: fld1jARxgeO5Xtiju']
    use_other boolean [note: 'business desc: Indicates whether the campaign intends to use Other types of media., technical desc: Type: checkbox, field ID: fldA0gfi6estfxXDA']
    other_media_types text [note: 'business desc: Optional field where the client can specify any additional media types not covered in the standard media placement options. Enables flexibility for unconventional requests and ensures the campaign brief captures all relevant execution preferences., technical desc: Type: richText, field ID: fldIRygAjeTPotKby']
    digital_percentage float [note: 'business desc: Percentage of the total budget allocated to Digital media., technical desc: Type: percent, field ID: fldBSVcsp7Oqs49aS']
    tv_percentage float [note: 'business desc: Percentage of the total budget allocated to TV media., technical desc: Type: percent, field ID: fldtZZ9ECtV089iBj']
    radio_percentage float [note: 'business desc: Percentage of the total budget allocated to Radio media., technical desc: Type: percent, field ID: fldfpcTb6P4Wo4guT']
    print_percentage float [note: 'business desc: Percentage of the total budget allocated to Print media., technical desc: Type: percent, field ID: fld1PRpriQEuHvmAY']
    unconventional_percentage float [note: 'business desc: Percentage of the total budget allocated to Unconventional media., technical desc: Type: percent, field ID: fldNGvvvIe6cWWVKU']
    other_percentage float [note: 'business desc: Percentage of the total budget allocated to Other media., technical desc: Type: percent, field ID: fldkBJlHJzxw4SEaA']
    reviewed_by varchar [note: 'business desc: User who reviewed and updated the project brief., technical desc: Type: singleCollaborator, field ID: fldZAaINXkQj2c3LB']
    created varchar [note: 'business desc: Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking., technical desc: Type: createdTime, field ID: fld1zjTrLvhT86dVi']
    media_allocation_validation varchar [note: 'business desc: Validates whether the total media allocation exceeds 100%. Displays a red warning if the combined percentages of all selected media types surpass 100%. Used for preventing over-allocation of campaign budgets., technical desc: Type: formula, field ID: fldiMvR9NmkMLlftz']
    last_modified_by varchar [note: 'business desc: Automatically records the user who made the most recent update to the project brief. Useful for tracking collaboration and accountability., technical desc: Type: lastModifiedBy, field ID: fldnpuzHDn822OSDK']
    campaign_creative_assets boolean [note: 'business desc: Indicates whether the client will provide creative assets for the campaign. If not selected, the internal design team will generate artwork based on campaign requirements., technical desc: Type: checkbox, field ID: fldHa98n7CGFUtRP8']
    last_modified varchar [note: 'business desc: Timestamp that reflects the most recent update to the record, enabling version tracking and operational visibility., technical desc: Type: lastModifiedTime, field ID: fldjNeKge7EwhD3Le']
    id int [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fldgoRDCTyjheljsZ']
    actual_q varchar [note: 'business desc: This formula compares the quarter of {start_date} to the current quarter (based on TODAY()) within the same year. It returns:

Q0 if the date is in the same quarter as the current one.

Q-1, Q-2, or Q-3 if it is 1, 2, or 3 quarters earlier, respectively.

An empty value if it falls outside that range or in a different year.

Use this to determine which quarter (relative to the current quarter) a record belongs to—helpful for segmenting or tracking past events within the current year.

, technical desc: Type: formula, field ID: fldzuVqYAYDlwIoA8']
    quarter_of_the_year varchar [note: 'business desc: his formula determines the quarter (Q1, Q2, Q3, or Q4) for the date in {start_date} and appends the respective year. The first part uses the month to calculate which quarter the date falls into; the second part adds the four-digit year. As a result, regardless of whether the date is in a past, current, or future year, you’ll see the quarter followed by the year, such as “Q3 2022” or “Q1 2025.” This is useful for quickly identifying the specific quarter and year of any given date., technical desc: Type: formula, field ID: fldjLnAk3DgCMNG3l']
    active_campaign int [note: 'business desc: This field connects an entry to its active marketing campaign.  Provides campaign tracking., technical desc: Type: multipleRecordLinks, Reference to active_campaign table, field ID: fldF9LH2bpo56VWSR']
    ai_context varchar [note: 'business desc: Generates a JSON object containing key campaign details from specified fields., technical desc: Type: aiText, field ID: fldRkQ6VkcfWTWvtp']
    clients int [note: 'business desc: This relationship connects orders to clients, enabling order tracking and client management., technical desc: Type: multipleRecordLinks, Reference to clients table, field ID: fldyVuxzYgthhEE4D']
    note: '### project_brief Table (airtable id: tblkmpqL98s7MydEh) - This table has 50 fields - This table consolidates all necessary data for evaluating and processing campaign briefs submitted by clients. It includes contact information, campaign details, target demographics, media preferences, geography targeting, and workflow status. This structure ensures standardized data collection, review, and collaboration for streamlined campaign approval   and execution workflows within the Grassroots CRM platform.'
}

