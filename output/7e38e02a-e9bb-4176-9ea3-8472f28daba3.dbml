Table clients {
    company_name varchar [note: 'business desc: Name of the company the client represents., technical desc: Type: singleLineText, field ID: fldyNBA0trS3bgYQP']
    client_name varchar [note: 'business desc: Full name of the client., technical desc: Type: singleLineText, field ID: fldZVET5TuecVfHVr']
    email varchar [note: 'business desc: Contact email for the client., technical desc: Type: email, field ID: fldfAP3xT0WVtrgLO']
    phone varchar [note: 'business desc: Contact phone number for the client., technical desc: Type: phoneNumber, field ID: fldGeQjk0iLMUPuWh']
    country varchar [note: 'business desc: Clients country of origin. Options: United States, technical desc: Type: singleSelect, Options: United States, field ID: fldEOvQb6ccY7psGz']
    state_province varchar [note: 'business desc: U.S. State of the client. Includes all 50 states., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld23R9uPQesuPBKj']
    city varchar [note: 'business desc: City where the client is based., technical desc: Type: singleLineText, field ID: fldcgcaHlUlkIlBah']
    website varchar [note: 'business desc: Website of the clients company, if available., technical desc: Type: url, field ID: fld7LJfC9F4IZoDQ5']
    created varchar [note: 'business desc: Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking., technical desc: Type: createdTime, field ID: fldPOolk92JYqOkoF']
    last_modified varchar [note: 'business desc: Timestamp that reflects the most recent update to the record, enabling version tracking and operational visibility., technical desc: Type: lastModifiedTime, field ID: fldGKvNSucdjQdBew']
    last_modified_by varchar [note: 'business desc: Automatically records the user who made the most recent update to the client record. Useful for tracking collaboration and accountability., technical desc: Type: lastModifiedBy, field ID: fldsPr7goHTlblK7M']
    project_brief int [note: 'business desc: Connects projects to their detailed briefs, providing context., technical desc: Type: multipleRecordLinks, Reference to project_brief table, field ID: fldbokg9mWK3KVZS1']
    active_campaign int [note: 'business desc: This relationship connects records, linking a record to its active campaign.  Provides campaign context., technical desc: Type: multipleRecordLinks, Reference to active_campaign table, field ID: fldR9PHX7rz7DSVRW']
    id int [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fld6DwWfSijqwBcEO']
    record_id varchar [note: 'business desc: System-generated unique identifier used for referencing this record across the platform and integrations., technical desc: Type: formula, field ID: fld7974ivOaW3eITT']
    note: '### clients Table (airtable id: tblchWDOuPzJczwMZ) - This table has 15 fields - This table stores information about clients submitting campaign briefs, including their contact details and organizational context. It serves as a master registry to link client identity with submitted and approved campaign records across the CRM system.'
}

Table media_placements {
