          "name": "created",
          "description": "Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking."
        },
        {
          "type": "lastModifiedBy",
          "id": "fld79bNf1ktlI4Gl4",
          "name": "last_modified_by",
          "description": "Automatically records the user who made the most recent update to the project brief. Useful for tracking collaboration and accountability."
        },
        {
          "type": "checkbox",
          "options": {
            "icon": "check",
            "color": "greenBright"
          },
          "id": "fldrUQmVvz1YAJFxs",
          "name": "campaign_creative_assets",
          "description": "Indicates whether the client will provide creative assets for the campaign. If not selected, the internal design team will generate artwork based on campaign requirements."
        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "IF(\r\n  YEAR({fld95S2mIfISCQZX8}) = YEAR(TODAY()),\r\n  SWITCH(\r\n    CEILING(MONTH({fld95S2mIfISCQZX8}) / 3) - CEILING(MONTH(TODAY()) / 3),\r\n    0,  \"Q0\",\r\n    -1, \"Q-1\",\r\n    -2, \"Q-2\",\r\n    -3, \"Q-3\",\r\n    \"\"\r\n  )\r\n)",
            "referencedFieldIds": [
              "fld95S2mIfISCQZX8"
            ],
            "result": {
              "type": "singleLineText"
            }
          },
          "id": "fldjeCEwYVYEcYcis",
          "name": "actual_q",
          "description": "This formula compares the quarter of {start_date} to the current quarter (based on TODAY()) within the same year. It returns:\n\nQ0 if the date is in the same quarter as the current one.\n\nQ-1, Q-2, or Q-3 if it is 1, 2, or 3 quarters earlier, respectively.\n\nAn empty value if it falls outside that range or in a different year.\n\nUse this to determine which quarter (relative to the current quarter) a record belongs to—helpful for segmenting or tracking past events within the current year.\n\n"
        },
        {
          "type": "formula",
          "options": {
            "isValid": true,
            "formula": "SWITCH(\r\n    CEILING(MONTH({fld95S2mIfISCQZX8}) / 3),\r\n    1, \"Q1\",\r\n    2, \"Q2\",\r\n    3, \"Q3\",\r\n    4, \"Q4\"\r\n)\r\n& \" \" &\r\nYEAR({fld95S2mIfISCQZX8})",
            "referencedFieldIds": [
              "fld95S2mIfISCQZX8"
            ],
            "result": {
              "type": "singleLineText"
            }
          },
          "id": "fld3v4OSrABVs3uLF",
          "name": "quarter_of_the_year",
          "description": "This formula determines the quarter (Q1, Q2, Q3, or Q4) for the date in {start_date} and appends the respective year. The first part uses the month to calculate which quarter the date falls into; the second part adds the four-digit year. As a result, regardless of whether the date is in a past, current, or future year, you’ll see the quarter followed by the year, such as “Q3 2022” or “Q1 2025.” This is useful for quickly identifying the specific quarter and year of any given date."
        },
