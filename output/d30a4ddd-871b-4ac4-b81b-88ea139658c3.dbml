    grade_level multipleSelects [note: 'business desc: The grade level of a student or course. Stores numerical values., technical desc: Type: multipleSelects, Options: PreK, K-2, 3-5, 6-8, 9-12, K-12, Higher Ed, 2025-10-01, 09:00, 14:00, 2025-09-15, 11:00, field ID: fldp895Ekq9jF69a8, readonly field: false']
    submission_type multipleSelects [note: 'business desc: Indicates the type of submission (e.g., application, report). Stores text strings., technical desc: Type: multipleSelects, Options: Online Submission via Portal, Email Submission, Mail-in Submission, Online and Mail-in, Online and Email, Mail-in and Email, 10:00, 3-5, 6-8, 9-12, PreK, K-2, K-12, Higher Ed, field ID: fld3IsyUvoWKF97dC, readonly field: false']
