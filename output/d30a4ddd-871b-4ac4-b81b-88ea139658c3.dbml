    keywords multipleSelects [note: 'business desc: Keywords associated with a product or record for search and categorization., technical desc: Type: multipleSelects, Options: Curriculum, Professional Development, Tech, Other, Awarded due to competitive pricing., http://drive.google.com/drive/folders/67890, http://drive.google.com/drive/folders/11223, Awarded for comprehensive service plan., http://drive.google.com/drive/folders/77889, field ID: fld9wvDSwZ1zbd8Rr, readonly field: false']
