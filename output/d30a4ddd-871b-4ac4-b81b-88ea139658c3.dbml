    users multipleRecordLinks [note: 'business desc: Connects a record to a specific user, providing context and ownership., technical desc: Type: multipleRecordLinks, Reference to users table, field ID: fldHxKeOcgbVHUAAo, readonly field: false']
    full_name_from_users multipleLookupValues [note: 'business desc: Stores the full name of users., technical desc: Type: multipleLookupValues, field ID: fld3k3meL1H0J4jMc, readonly field: true']
    note: '### pars Table (airtable id: tblN31mzcAPHjAQtA) - pars - Table for managing pars information'
