    pre_proposal_conference_info multilineText [note: 'business desc: Information about a conference for a pre-proposal., technical desc: Type: multilineText, field ID: fldOfCM8TGerFvQR8, readonly field: false']
    qna_details multilineText [note: 'business desc: Stores detailed Q&A information., technical desc: Type: multilineText, field ID: fldTL8o5Ehno5SrwU, readonly field: false']
    addendum_information multilineText [note: 'business desc: Supplementary details about a record. Stores text-based information., technical desc: Type: multilineText, field ID: fldEdeYi8pGoc0OMY, readonly field: false']
    submission_status singleSelect [note: 'business desc: The submission status indicates whether a submission is pending, in progress, or completed., technical desc: Type: singleSelect, Options: Not Responding, Not Yet Submitted, Submitted, All Q&As will be posted online., No addendums expected., Addendum #1 issued on 2025-11-01., Q&A closed., Addendum #2 expected., field ID: fldsAIOFo42O9Mfam, readonly field: false']
    contract_or_bid singleSelect [note: 'business desc: Indicates if a record is for a contract or bid. Stores a text value (e.g., contract, bid)., technical desc: Type: singleSelect, Options: Contract, Bid, Addendum will be uploaded as needed., Submitted, Not Responding, No addendums., Not Yet Submitted, field ID: fld7T68hXZ5e5Cm34, readonly field: false']
    award_status singleSelect [note: 'business desc: Indicates whether an award was granted or rejected. Stores granted or rejected., technical desc: Type: singleSelect, Options: Won, Lost, RFP Cancelled / Not Awarding, Did Not Submit, Not Yet Submitted, Contract, Bid, Submitted, field ID: fldW4w9J7hCyDXCOw, readonly field: false']
    award_notes multilineText [note: 'business desc: Notes about awards received. Free-form text., technical desc: Type: multilineText, field ID: fld7t02oR6VyEnj5e, readonly field: false']
