    state singleSelect [note: 'business desc: Stores the state of a location. Two-letter abbreviation., technical desc: Type: singleSelect, Options: AL, AK, AZ, AR, CA, CO, CT, DE, FL, GA, HI, ID, IL, IN, IA, KS, KY, LA, ME, MD, MA, MI, MN, MS, MO, MT, NE, NV, NH, NJ, NM, NY, NC, ND, OH, OK, OR, PA, RI, SC, SD, TN, TX, UT, VT, VA, WA, WV, WI, WY, field ID: fld3ovUIDhVlCZztp, readonly field: false']
    district_size singleSelect [note: 'business desc: The district size field stores the area of a geographic district in a standardized unit., technical desc: Type: singleSelect, Options: Small District (<5,000 students), Medium District (5,000–25,000 students), Large District (25,000+ students), State Level, Other, Medium District (5, Large District (25, Small District (<5, field ID: fldcYR7Q19a2bAmvt, readonly field: false']
