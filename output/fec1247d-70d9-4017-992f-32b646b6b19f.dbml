Table Projects {
    Project_Name singleLineText [note: 'business desc: The name of a project. Stores text strings., technical desc: Type: singleLineText, field ID: flde9nkmcWluFjlBL']
    Project_Description multilineText [note: 'business desc: A detailed summary of the projects goals and scope., technical desc: Type: multilineText, field ID: fldiEKmb9ZYSoyN1L']
    Start_Date date [note: 'business desc: The date a task or project begins. Stores a date value., technical desc: Type: date, Format: l, field ID: flddfoq8JO0ZFTgUl']
    End_Date date [note: 'business desc: The date a task or project is scheduled to end., technical desc: Type: date, Format: l, field ID: fldqbep2VfqZdQV0a']
    Budget currency [note: 'business desc: The Budget field represents the allocated financial resources for a specific project or activity. It stores a monetary value., technical desc: Type: currency, Precision: 2, Symbol: $, field ID: fldwSnUixvTQtfYTP']
    Project_Photo multipleAttachments [note: 'business desc: Image representing the project., technical desc: Type: multipleAttachments, field ID: fldtTDzma5QlIzUwV']
    Related_Tasks multipleRecordLinks [note: 'business desc: This relationship connects tasks to related tasks, enabling task organization and dependencies., technical desc: Type: multipleRecordLinks, Reference to Tasks table, field ID: fldyxXB2b7kDAuFlI']
    Project_Type multipleRecordLinks [note: 'business desc: This relationship connects projects to their types, providing project categorization for analysis and reporting., technical desc: Type: multipleRecordLinks, Reference to Project_Types table, field ID: fldsLfwh7TzVj3SGv']
    Total_Tasks count [note: 'business desc: The total number of tasks assigned. Integer value., technical desc: Type: count, field ID: fldee3nvEQPsLZhJj']
    Completed_Tasks rollup [note: 'business desc: A list of tasks marked as completed., technical desc: Type: rollup, field ID: fld2Ow1MTuR8GBqKj']
    Task_Completion_Rate formula [note: 'business desc: Percentage of completed tasks. Represents task efficiency., technical desc: Type: formula, field ID: fld26KIqwDgK78QeA']
    Project_Duration formula [note: 'business desc: The time it takes to complete a project. Stores duration in a specific unit., technical desc: Type: formula, field ID: fldFZzFFZEF1KyIY3']
    Project_Summary aiText [note: 'business desc: A concise summary of the projects goals and key aspects., technical desc: Type: aiText, field ID: fldJSxl0dpybUTpoi']
    Next_Steps_Suggestion aiText [note: 'business desc: Recommended actions following a task or process. Strings/text., technical desc: Type: aiText, field ID: fld5Pt89DuxtBuGnw']
    note: '### Projects Table (airtable id: tblEb7Fmj8Sv7wc2R) - This table has 14 fields - This table has 14 fields - The Projects table stores information about all company projects, including details like names, descriptions, and deadlines. It tracks project progress.'
}

Table Tasks {
    Task_Name singleLineText [note: 'business desc: The name of a task to be performed. Stores text descriptions., technical desc: Type: singleLineText, field ID: flduEmnjgAw7iJFqy']
    Task_Description multilineText [note: 'business desc: Describes the tasks details and actions needed., technical desc: Type: multilineText, field ID: fldoUNx1gs2uLVY1Z']
    Assigned_To singleLineText [note: 'business desc: The user or team assigned a task or project. Stores names/IDs., technical desc: Type: singleLineText, field ID: fldNQ3fYP4C5EFLDN']
    Due_Date date [note: 'business desc: The date a task or payment is expected to be completed., technical desc: Type: date, Format: l, field ID: fldl7tb6AzIpadPAx']
    Status singleSelect [note: 'business desc: Indicates the current state of a record. Stores text values like Open, Closed, Pending., technical desc: Type: singleSelect, Options: Not Started, In Progress, Completed, Blocked, field ID: fldKhmBmjYztWb3WM']
    Progress number [note: 'business desc: Progress tracks project completion percentage. Stores a numeric value., technical desc: Type: number, field ID: fldpRhywbXeOwGTom']
    Related_Project multipleRecordLinks [note: 'business desc: This Related Project field connects projects with related projects, enabling project grouping and resource allocation., technical desc: Type: multipleRecordLinks, Reference to Projects table, field ID: fld5erXVtacWHY0Ob']
    Project_Type multipleRecordLinks [note: 'business desc: Project Type connects projects to specific project types, enabling categorization and reporting., technical desc: Type: multipleRecordLinks, Reference to Project_Types table, field ID: fldi6BNJrVl45Lfgp']
    Attachments multipleAttachments [note: 'business desc: Files attached to a record. Stores various document types., technical desc: Type: multipleAttachments, field ID: fldV756xXaoUzfeRP']
    Review_Photos multipleAttachments [note: 'business desc: Images related to customer reviews., technical desc: Type: multipleAttachments, field ID: fldEMVVMQEOl1IfoI']
    Project_Type_Complexity multipleLookupValues [note: 'business desc: Describes the level of complexity for a project type. Stores a categorical value., technical desc: Type: multipleLookupValues, field ID: fld28DGOfpcY5sRtY']
    Task_Completion_Percentage formula [note: 'business desc: Percentage of completed tasks. Numeric data., technical desc: Type: formula, field ID: fld20RgeKRPln0104']
    Days_Until_Due formula [note: 'business desc: Number of days remaining before a task/item is due., technical desc: Type: formula, field ID: fldvUwFzWzFDKa1vb']
    Related_Project_Budget multipleLookupValues [note: 'business desc: The budget allocated to related projects. Numeric value., technical desc: Type: multipleLookupValues, field ID: fldIfwDXj9m7weaKJ']
    Task_Summary aiText [note: 'business desc: A brief description of the tasks purpose and key details., technical desc: Type: aiText, field ID: fldGTDqnbooGmJTRw']
    Next_Action_Recommendation aiText [note: 'business desc: Recommended next steps for a task/project. Stores text descriptions., technical desc: Type: aiText, field ID: fldhyQN8BdjygDHiu']
    note: '### Tasks Table (airtable id: tblE8XUvw79TlShnl) - This table has 16 fields - This table has 16 fields - The Tasks table stores information about all work items needing completion within the organization. It tracks details like description and status.'
}

Table Project_Types {
    Project_Type_Name singleLineText [note: 'business desc: Stores the name of a projects type (e.g., marketing, development)., technical desc: Type: singleLineText, field ID: fldCuL9pmUvz93SGi']
    Description multilineText [note: 'business desc: Describes the item or event in detail. Stores text data., technical desc: Type: multilineText, field ID: fldEjl2ro9qgKfbJb']
    Default_Duration__Days number [note: 'business desc: The default number of days for a task or project., technical desc: Type: number, field ID: fldYngZXc6XgHl9w4']
    Budget_Range currency [note: 'business desc: The price range for a product or service. Stores numerical values., technical desc: Type: currency, Precision: 2, Symbol: $, field ID: fld4sI0ZoXniWdUsS']
    Complexity_Level singleSelect [note: 'business desc: Indicates the difficulty level of a task or project. Stores a descriptive level (e.g., Low, Medium, High)., technical desc: Type: singleSelect, Options: Low, Medium, High, field ID: fld2GZX0YXkAonV2a']
    Related_Projects multipleRecordLinks [note: 'business desc: This relationship connects projects with other projects, showing collaborations or dependencies. Provides project context., technical desc: Type: multipleRecordLinks, Reference to Projects table, field ID: fldvLAO4RGA2ryEt6']
    Average_Project_Budget rollup [note: 'business desc: Average cost of a project. Stores numerical data., technical desc: Type: rollup, field ID: flduMlFrGEmFSi7Xe']
    Total_Number_of_Projects count [note: 'business desc: The total number of projects currently active or completed., technical desc: Type: count, field ID: fldCT0S4lwBSPuCf2']
    Project_Type_Summary aiText [note: 'business desc: Summary of a projects type and categories., technical desc: Type: aiText, field ID: fldVpnbgQlwHIdbZb']
    Task_Recommendations aiText [note: 'business desc: Suggested tasks for users based on past actions., technical desc: Type: aiText, field ID: flddUNhTky7UmJboO']
    Tasks multipleRecordLinks [note: 'business desc: This relationship connects records, linking tasks to their related items. Provides context and organization., technical desc: Type: multipleRecordLinks, Reference to Tasks table, field ID: fldtWEqH7EYl5RCOd']
    note: '### Project_Types Table (airtable id: tblJ6x7JheQfghJnQ) - This table has 11 fields - This table has 11 fields - The Project Types table stores different project categories used to categorize projects. It defines project types and their properties for project management.'
}

