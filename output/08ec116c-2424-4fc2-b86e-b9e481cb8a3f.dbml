        },
        {
          "type": "multipleAttachments",
          "options": {
            "isReversed": false
          },
          "id": "fldS8yo3b7jdDyxYZ",
          "name": "cv"
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldS8yo3b7jdDyxYZ"
            ],
            "prompt": [
              "You are a text extraction specialist tasked with extracting text from documents.\n\nYour task is to extract the full text from the document provided in the 'cv' field. Ensure that the text is extracted accurately and completely, without any modifications or omissions.\n\nOutput the extracted text as plain text without any additional formatting or text. If the document is empty or unreadable, output \"No text available.\"\n\nDocument: ",
              {
                "field": {
                  "fieldId": "fldS8yo3b7jdDyxYZ"
                }
              },
              "\nOutput:"
            ]
          },
          "id": "fldQDRQxEnOLN28AK",
          "name": "extracted_cv_text",
          "description": "Extracts and displays the full text from the CV document."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldQDRQxEnOLN28AK"
            ],
            "prompt": [
              "You are an AI specialized in analyzing text content to determine its main topics and themes. Your task is to read the extracted text from a CV and identify the primary subjects it covers.\n\nBegin by carefully reviewing the text to understand the key areas of expertise, skills, and experiences mentioned. Focus on identifying the main topics that are emphasized throughout the document.\n\nOutput the main topics as a comma-separated list in plain text. If you cannot determine the topics, output \"Unable to determine topics.\" Do not include any additional text or explanations.\n\nContext and Data:\nExtracted CV Text: ",
              {
                "field": {
                  "fieldId": "fldQDRQxEnOLN28AK"
                }
              },
              "\n\nOutput:"
            ]
          },
          "id": "fld1mMGGOKLD5LbU1",
          "name": "cv_topic_analysis",
          "description": "Analyzes the extracted CV text to identify the main topics covered."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldkEzCseu4rPhdSR"
            ],
            "prompt": [
              "You are a text extraction specialist tasked with extracting full text from document attachments. Focus on accurately retrieving all text content from the provided attachments without altering the original text.\n\nTask description:\nExtract the full text from the document attachments provided in the row. Ensure that all text is captured accurately and completely, maintaining the original formatting as much as possible.\n\nOutput format:\nProvide the extracted text as plain text without any additional formatting or commentary. If no text can be extracted, output \"No text available.\" Ensure the text is complete and accurate, e.g., \"This is the full text from the document.\" (Real examples should be longer and reflect the actual content of the document.)\n\nContext and Data:\nAttachments: ",
              {
                "field": {
                  "fieldId": "fldkEzCseu4rPhdSR"
                }
              },
              "\n\nOutput:\n"
            ]
          },
          "id": "fld568cciSzp72bnT",
          "name": "full_text",
          "description": "Extracts the full text from the document attachments in the attachment_style column."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldkEzCseu4rPhdSR"
            ],
            "prompt": [
              "You are a literary analyst specializing in identifying and replicating writing styles. Your task is to extract and analyze the text from the provided attachment to identify the unique style DNA, modisms, and imperfections of the writer.\n\nBegin by thoroughly reading the text in the attachment, noting any distinctive language patterns, recurring phrases, and stylistic choices. Pay attention to any imperfections or idiosyncrasies that characterize the writer's style.\n\nOutput a concise analysis of the writer's style, focusing on key elements such as tone, vocabulary, and sentence structure. Format your response as plain text, without headings or additional text, and include specific examples from the text. If you cannot identify the style, output \"Unable to determine style.\" Ensure the output is clear and detailed, e.g., \"The writer frequently uses short, punchy sentences and informal language, with a tendency to repeat certain phrases like 'you know'.\"\n\nContext and Data:\nAttachment: ",
              {
                "field": {
                  "fieldId": "fldkEzCseu4rPhdSR"
                }
              },
              "\n\nOutput:"
            ]
          },
          "id": "fldSQtTAVTWy5IHUm",
          "name": "style_dna_analysis",
          "description": "Analyzes the text from the attachment to identify the writer's style DNA, modisms, and imperfections."
        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld568cciSzp72bnT",
              "fldSQtTAVTWy5IHUm"
            ],
            "prompt": [
              "You are a writing style analyst specializing in evaluating and providing insights on written content. Your expertise includes identifying strengths and areas for improvement in writing style, focusing on tone, vocabulary, and structure.\n\nTask description:\nAnalyze the provided text to identify key characteristics of the writing style. Highlight strengths in tone, vocabulary, and structure, and suggest areas where the style could be improved. Avoid general comments and focus on specific elements that define the writing style.\n\nOutput format:\nProvide a concise analysis of the writing style in plain text. Include strengths and areas for improvement, formatted as bullet points. If unable to identify any insights, output \"No insights available.\"\n\nContext and Data:\nFull Text: ",
              {
                "field": {
                  "fieldId": "fld568cciSzp72bnT"
                }
              },
              "\nStyle DNA: ",
              {
                "field": {
                  "fieldId": "fldSQtTAVTWy5IHUm"
                }
              },
              "\n\nOutput:\n"
            ]
          },
          "id": "fldjzl37rA1Xwf2MY",
          "name": "writing_Style_Insights"
        },
        {
          "type": "singleSelect",
          "options": {
            "choices": [
              {
                "id": "selRHWdS6spmG6dYl",
                "name": "Marketing",
                "color": "blueLight2"
              },
              {
                "id": "selj7NyJKBMN6DZXs",
                "name": "AI",
                "color": "cyanLight2"
              },
              {
                "id": "selbCdJSR499Aw0jR",
                "name": "Operations",
                "color": "tealLight2"
              }
            ]
          },
          "id": "fldd6Zu8jvxI7TX8f",
          "name": "topic"
        },
        {
          "type": "multipleRecordLinks",
          "options": {
            "linkedTableId": "tbl6YuhPy5vOKK2oO",
            "isReversed": false,
            "prefersSingleRecordLink": true,
            "inverseLinkFieldId": "fldxyw3mkFeq5THr7"
