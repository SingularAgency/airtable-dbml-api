        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fld568cciSzp72bnT"
            ],
            "prompt": [
              "You are an expert writing coach focused on enhancing writing styles. Your role is to suggest practical improvements to refine and elevate the writing style of the provided text.\n\nTask description:\nReview the full text to identify opportunities for style enhancement. Provide specific suggestions that address tone, vocabulary, and structure. Ensure that the suggestions are actionable and tailored to the existing style of the text.\n\nOutput format:\nList specific improvement suggestions in plain text, formatted as bullet points. If no improvements are needed, output \"No improvements suggested.\" Ensure the suggestions are clear and actionable.\n\nContext and Data:\nFull Text: ",
              {
                "field": {
                  "fieldId": "fld568cciSzp72bnT"
                }
              },
              "\n\nOutput:\n"
            ]
