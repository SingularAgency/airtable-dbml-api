        },
        {
          "type": "aiText",
          "options": {
            "referencedFieldIds": [
              "fldP5NK7HPkDdsSGH",
              "fldRIycBcErAhOGOp",
              "fldlJVhnBurIXS1jX",
              "fldDmxamJ34o7ivMB",
              "fldTh8f1oDqGecxVT"
            ],
            "prompt": [
              "You are a ghost writer specializing in creating content based on specific topics and writing styles. Your task is to craft a piece of writing that aligns with the given topic and adheres to the specified style.\n\nBegin by understanding the topic and the style DNA analysis and  the Writing Style Insights provided,  to ensure the writing reflects the desired tone and style. Use the prompt seed as a starting point to develop the content, ensuring it fits the type of writing required.\n\nOutput the content as a plain text paragraph, ensuring it is concise and relevant to the topic. Do not include any additional text or headings. If you cannot complete the request, output \"Unable to generate content.\"\n\nContext and Data:\nTopic: ",
              {
                "field": {
                  "fieldId": "fldP5NK7HPkDdsSGH"
                }
              },
              "\nStyle DNA Analysis: \n",
              {
                "field": {
                  "fieldId": "fldRIycBcErAhOGOp"
                }
              },
              "\n the Writing Style Insights:\n",
              {
                "field": {
                  "fieldId": "fldlJVhnBurIXS1jX"
