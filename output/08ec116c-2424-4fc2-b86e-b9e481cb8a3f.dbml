            "formula": "IF({fldO3pzGl7vC9GmE0} >= 8, 'High', IF({fldO3pzGl7vC9GmE0} >= 5, 'Medium', 'Low'))",
            "referencedFieldIds": [
              "fldO3pzGl7vC9GmE0"
            ],
