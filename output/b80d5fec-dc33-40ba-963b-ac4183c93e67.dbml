    autheinticated_account checkbox [note: 'business desc: Cuando el cliente ya es un usuario autenticado, technical desc: Type: checkbox, field ID: fldm08k8JbRe8Hx9z']
    PII_sensitivity_level singleSelect [note: 'business desc: Classifies the sensitivity level of personal data fields according to GDPR standards., technical desc: Type: singleSelect, Options: Non-Sensitive, Sensitive, Confidential, Highly Confidential, field ID: fld0iQrYXwMPGqlLU']
    id autoNumber [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fld6DwWfSijqwBcEO']
    project_brief_copy singleLineText [note: 'business desc: A copy of the projects initial description., technical desc: Type: singleLineText, field ID: fld9t0KJ4vNSGR0YP']
    contract multipleAttachments [note: 'business desc: A contract, detailing terms and conditions of an agreement., technical desc: Type: multipleAttachments, field ID: fldydafkYxZNB0Mph']
    create_contract button [note: 'business desc: Date a contract was created. Stores a date/time value., technical desc: Type: button, field ID: fldvzwLDz4xtiP9vm']
    today_date formula [note: 'business desc: Stores the date of the current day., technical desc: Type: formula, field ID: fldkpW6cJprAW9gE6']
    note: '### advertisers Table (airtable id: tblchWDOuPzJczwMZ) - This table stores information about clients submitting campaign briefs, including their contact details and organizational context. It serves as a master registry to link client identity with submitted and approved campaign records across the CRM system.'
}

Table project_brief {
