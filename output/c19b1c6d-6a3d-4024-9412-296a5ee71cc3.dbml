    all_campaigns_without_active_campaign multipleRecordLinks [note: 'business desc: This field connects orders to their associated active marketing campaign. Provides campaign tracking., technical desc: Type: multipleRecordLinks, Reference to active_campaign table, field ID: fldIz2ozHBJeqABO3, readonly field: false']
