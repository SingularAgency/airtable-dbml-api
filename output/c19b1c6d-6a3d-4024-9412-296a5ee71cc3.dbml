    state_province singleSelect [note: 'business desc: U.S. state or province of the client. Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld4DMGJCCrSWKUkR, readonly field: false']
    city multilineText [note: 'business desc: City where the client is located., technical desc: Type: multilineText, field ID: fld5thsP74HlOEFHf, readonly field: false']
    website url [note: 'business desc: Optional website link provided by the client., technical desc: Type: url, field ID: fldBqgWxlsN1Y3gsy, readonly field: false']
    campaign_title multilineText [note: 'business desc: Name/title of the campaign., technical desc: Type: multilineText, field ID: fldDMrRgz0Ihg58br, readonly field: false']
    primary_objective multilineText [note: 'business desc: Primary goal or objective of the campaign., technical desc: Type: multilineText, field ID: fld8ZFCdfHHRfmBm6, readonly field: false']
    budget currency [note: 'business desc: Estimated campaign budget in USD., technical desc: Type: currency, Precision: 2, Symbol: $, field ID: fldkR1adM2ETcjGIQ, readonly field: false']
    start_date date [note: 'business desc: Planned start date of the campaign., technical desc: Type: date, Format: M/D/YYYY, field ID: fldplbOOkinzWAbfO, readonly field: false']
    end_date date [note: 'business desc: Planned end date of the campaign., technical desc: Type: date, Format: M/D/YYYY, field ID: fldQ3CDax6MO4xViW, readonly field: false']
    age_range_min number [note: 'business desc: Minimum age of the campaign target audience., technical desc: Type: number, field ID: fldOPc7TaJVKjkZbu, readonly field: false']
    age_range_max number [note: 'business desc: Maximum age of the campaign target audience., technical desc: Type: number, field ID: fldq0wvsziVXD891Y, readonly field: false']
    target_geography_state singleSelect [note: 'business desc: U.S. state targeted by the campaign. Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming., technical desc: Type: singleSelect, Options: Alabama, Alaska, Arizona, Arkansas, California, Colorado, Connecticut, Delaware, Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Kentucky, Louisiana, Maine, Maryland, Massachusetts, Michigan, Minnesota, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New Mexico, New York, North Carolina, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, Rhode Island, South Carolina, South Dakota, Tennessee, Texas, Utah, Vermont, Virginia, Washington, West Virginia, Wisconsin, Wyoming, field ID: fld1YJeEfDgUKlU9e, readonly field: false']
    target_geography_city multilineText [note: 'business desc: City targeted by the campaign., technical desc: Type: multilineText, field ID: fldwZmKKwYJP467J3, readonly field: false']
    target_communities multipleSelects [note: 'business desc: Demographic communities targeted by the campaign. Options: African American, Caribbean, Arab, East Asian, U.S. Indigenous, Indian American, Latino/Hispanic, Russian, South Asian, Southeast Asian, Jewish, Pacific Islander, East Slavic, West European, West African, Other., technical desc: Type: multipleSelects, Options: African American, Caribbean, Polish, East Asian, U.S. Indigenous, Indian American, Latino/Hispanic Russian, South Asian, Southeast Asian, Jewish, Pacific Islander, East Slavic, West European, West African, Other, Russian, Latino/Hispanic, field ID: fldpACPXF0jVRlEKR, readonly field: false']
    preferred_media_placements multipleSelects [note: 'business desc: Types of media preferred for ad placement. Options: Digital, Print, Radio, TV, Unconventional, Other., technical desc: Type: multipleSelects, Options: Digital, Print, Radio, TV, Unconventional, Other, field ID: fldOeMTg5OeQH7UCQ, readonly field: false']
    target_audience_details multilineText [note: 'business desc: Additional details about audience demographics or behaviors., technical desc: Type: multilineText, field ID: fldopT6JQbKMWOopp, readonly field: false']
    uploaded_documents multipleAttachments [note: 'business desc: Supporting files for the campaign brief., technical desc: Type: multipleAttachments, field ID: fldhmFcXIAT0GaZsv, readonly field: false']
    status singleSelect [note: 'business desc: Current review status (Options: Pending Review, Approved, Rejected)., technical desc: Type: singleSelect, Options: Pending Review, Approved, Rejected, field ID: fldv6J8hLAFYs86lx, readonly field: false']
    review_notes richText [note: 'business desc: Internal notes added by reviewer., technical desc: Type: richText, field ID: fldUCwNbON6q9J5qj, readonly field: false']
    ai_review_notes aiText [note: 'business desc: Notes from AI on a review, describing findings and suggestions., technical desc: Type: aiText, field ID: fld48ZG69AXyAc0Fj, readonly field: false']
    use_digital checkbox [note: 'business desc: Indicates whether the campaign intends to use Digital media., technical desc: Type: checkbox, field ID: fldY0c3snhZkTJg9m, readonly field: false']
    use_tv checkbox [note: 'business desc: Indicates whether the campaign intends to use TV media., technical desc: Type: checkbox, field ID: fldYFhulETK12NIcO, readonly field: false']
    use_radio checkbox [note: 'business desc: Indicates whether the campaign intends to use Radio media., technical desc: Type: checkbox, field ID: fldBwaNwZ2u4Gc7Q8, readonly field: false']
    use_print checkbox [note: 'business desc: Indicates whether the campaign intends to use Print media., technical desc: Type: checkbox, field ID: fldDBrFY6Gbth8ysF, readonly field: false']
    use_Nontraditional checkbox [note: 'business desc: Indicates whether the campaign intends to use Unconventional media., technical desc: Type: checkbox, field ID: fld1jARxgeO5Xtiju, readonly field: false']
    use_other checkbox [note: 'business desc: Indicates whether the campaign intends to use Other types of media., technical desc: Type: checkbox, field ID: fldA0gfi6estfxXDA, readonly field: false']
    other_media_types richText [note: 'business desc: Optional field where the client can specify any additional media types not covered in the standard media placement options. Enables flexibility for unconventional requests and ensures the campaign brief captures all relevant execution preferences., technical desc: Type: richText, field ID: fldIRygAjeTPotKby, readonly field: false']
    digital_percentage percent [note: 'business desc: Percentage of the total budget allocated to Digital media., technical desc: Type: percent, field ID: fldBSVcsp7Oqs49aS, readonly field: false']
    tv_percentage percent [note: 'business desc: Percentage of the total budget allocated to TV media., technical desc: Type: percent, field ID: fldtZZ9ECtV089iBj, readonly field: false']
    radio_percentage percent [note: 'business desc: Percentage of the total budget allocated to Radio media., technical desc: Type: percent, field ID: fldfpcTb6P4Wo4guT, readonly field: false']
    print_percentage percent [note: 'business desc: Percentage of the total budget allocated to Print media., technical desc: Type: percent, field ID: fld1PRpriQEuHvmAY, readonly field: false']
    unconventional_percentage percent [note: 'business desc: Percentage of the total budget allocated to Unconventional media., technical desc: Type: percent, field ID: fldNGvvvIe6cWWVKU, readonly field: false']
    other_percentage percent [note: 'business desc: Percentage of the total budget allocated to Other media., technical desc: Type: percent, field ID: fldkBJlHJzxw4SEaA, readonly field: false']
    reviewed_by singleCollaborator [note: 'business desc: User who reviewed and updated the project brief., technical desc: Type: singleCollaborator, field ID: fldZAaINXkQj2c3LB, readonly field: false']
    created createdTime [note: 'business desc: Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking., technical desc: Type: createdTime, field ID: fld1zjTrLvhT86dVi, readonly field: true']
    media_allocation_validation formula [note: 'business desc: Validates whether the total media allocation exceeds 100%. Displays a red warning if the combined percentages of all selected media types surpass 100%. Used for preventing over-allocation of campaign budgets., technical desc: Type: formula, field ID: fldiMvR9NmkMLlftz, readonly field: true']
    last_modified_by lastModifiedBy [note: 'business desc: Automatically records the user who made the most recent update to the project brief. Useful for tracking collaboration and accountability., technical desc: Type: lastModifiedBy, field ID: fldnpuzHDn822OSDK, readonly field: true']
    campaign_creative_assets checkbox [note: 'business desc: Indicates whether the client will provide creative assets for the campaign. If not selected, the internal design team will generate artwork based on campaign requirements., technical desc: Type: checkbox, field ID: fldHa98n7CGFUtRP8, readonly field: false']
    ai_context aiText [note: 'business desc: Generates a JSON object containing key campaign details from specified fields., technical desc: Type: aiText, field ID: fldRkQ6VkcfWTWvtp, readonly field: false']
    contract_pdf multipleAttachments [note: 'business desc: Stores a PDF of the contract document., technical desc: Type: multipleAttachments, field ID: fldk8JcJodsGYEomj, readonly field: false']
    commission_percentage_number number [note: 'business desc: The commission percentage a salesperson earns. Numeric value., technical desc: Type: number, field ID: fldDXcLNEbgMiyMag, readonly field: false']
    commission_amount formula [note: 'business desc: The commission amount paid for a transaction. Numeric value., technical desc: Type: formula, field ID: fldblZ1gYnkwfqjy1, readonly field: true']
    net_budget formula [note: 'business desc: Net budget: The remaining funds after expenses., technical desc: Type: formula, field ID: fldYNYurcg9C4HQTR, readonly field: true']
    last_modified lastModifiedTime [note: 'business desc: Timestamp that reflects the most recent update to the record, enabling version tracking and operational visibility., technical desc: Type: lastModifiedTime, field ID: fldjNeKge7EwhD3Le, readonly field: true']
    id autoNumber [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fldgoRDCTyjheljsZ, readonly field: true']
    actual_q formula [note: 'business desc: This formula compares the quarter of start_date to the current quarter (based on TODAY()) within the same year. It returns: Q0 if the date is in the same quarter as the current one. Q-1, Q-2, or Q-3 if it is 1, 2, or 3 quarters earlier, respectively. An empty value if it falls outside that range or in a different year. Use this to determine which quarter (relative to the current quarter) a record belongs to—helpful for segmenting or tracking past events within the current year., technical desc: Type: formula, field ID: fldzuVqYAYDlwIoA8, readonly field: true']
    quarter_of_the_year formula [note: 'business desc: his formula determines the quarter (Q1, Q2, Q3, or Q4) for the date in start_date and appends the respective year. The first part uses the month to calculate which quarter the date falls into; the second part adds the four-digit year. As a result, regardless of whether the date is in a past, current, or future year, you’ll see the quarter followed by the year, such as “Q3 2022” or “Q1 2025.” This is useful for quickly identifying the specific quarter and year of any given date., technical desc: Type: formula, field ID: fldjLnAk3DgCMNG3l, readonly field: true']
    active_campaign multipleRecordLinks [note: 'business desc: Connects records to their associated active marketing campaign. Increases campaign tracking and analysis., technical desc: Type: multipleRecordLinks, Reference to active_campaign table, field ID: fldF9LH2bpo56VWSR, readonly field: false']
    clients multipleRecordLinks [note: 'business desc: Clients field connects advertisers to their customers. Provides customer context for ad campaigns., technical desc: Type: multipleRecordLinks, Reference to advertisers table, field ID: fldyVuxzYgthhEE4D, readonly field: false']
    first_ai_summary multilineText [note: 'business desc: The first AI-generated summary of the document., technical desc: Type: multilineText, field ID: fldXb3wf4Jij8ViyA, readonly field: false']
    first_ai_strategic_insights multilineText [note: 'business desc: First strategic AI insights document. Stores initial AI analysis., technical desc: Type: multilineText, field ID: fld4vXq2YW741kRqp, readonly field: false']
    jwt_anonymous multilineText [note: 'business desc: JWT token para validar cliente nuevo, technical desc: Type: multilineText, field ID: fldNS8ENtX98ehEUF, readonly field: false']
    note: '### project_brief Table (airtable id: tblkmpqL98s7MydEh) - This table consolidates all necessary data for evaluating and processing campaign briefs submitted by clients. It includes contact information, campaign details, target demographics, media preferences, geography targeting, and workflow status. This structure ensures standardized data collection, review, and collaboration for streamlined campaign approval and execution workflows within the Grassroots CRM platform.'
}

