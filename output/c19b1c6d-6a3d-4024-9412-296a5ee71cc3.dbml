    city singleLineText [note: 'business desc: City where the client is based., technical desc: Type: singleLineText, field ID: fldcgcaHlUlkIlBah, readonly field: false']
    website url [note: 'business desc: Website of the clients company, if available., technical desc: Type: url, field ID: fld7LJfC9F4IZoDQ5, readonly field: false']
    record_id formula [note: 'business desc: System-generated unique identifier used for referencing this record across the platform and integrations., technical desc: Type: formula, field ID: fld7974ivOaW3eITT, readonly field: true']
    created createdTime [note: 'business desc: Timestamp automatically captured when the record is first created, supporting audit trails and chronological tracking., technical desc: Type: createdTime, field ID: fldPOolk92JYqOkoF, readonly field: true']
