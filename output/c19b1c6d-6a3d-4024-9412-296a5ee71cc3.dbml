    today_date formula [note: 'business desc: Stores the date of the current day., technical desc: Type: formula, field ID: fldkpW6cJprAW9gE6, readonly field: true']
    advertiser_address singleLineText [note: 'business desc: The advertisers physical street address., technical desc: Type: singleLineText, field ID: fldKeM8qDAedeuDu6, readonly field: false']
    advertiser_postal_code singleLineText [note: 'business desc: The postal code of the advertiser., technical desc: Type: singleLineText, field ID: fldpncgbKpHlEQwFX, readonly field: false']
    advertiser_enterprise_structure singleSelect [note: 'business desc: Represents the organizational structure of the advertiser. Stores hierarchical data., technical desc: Type: singleSelect, Options: Limited Liability Company, C Corporation, S Corporation, Limited Liability Partnership, Sole Proprietorship, field ID: fldMbrNZzesJKiPG5, readonly field: false']
    advertiser_industry singleSelect [note: 'business desc: The advertisers industry sector. Stores categorical data., technical desc: Type: singleSelect, Options: Agriculture, Architecture, Arts & Culture, Automotive, Aviation, Biotechnology, Broadcast Media, Business Services, Chemicals, Construction, Consumer Electronics, Consumer Goods, Design, E-commerce, Education, Energy, Engineering, Entertainment, Environmental Services, Events Services, Fashion, Finance, Financial Services, Food & Beverage, Gambling & Casinos, Government, Healthcare, Hospitality, Human Resources, Information Technology, Insurance, Legal Services, Logistics & Supply Chain, Manufacturing, Marketing & Advertising, Media Production, Medical Devices, Mining & Metals, Motion Pictures & Film, Museums & Institutions, Music, Nanotechnology, Nonprofit Organization Management, Oil & Gas, Pharmaceuticals, Photography, Politics, Public Relations, Publishing, Real Estate, Renewables & Environment, Research, Restaurants, Retail, Security & Investigations, Shipbuilding, Software, Sports, Telecommunications, Textiles, Tobacco, Translation & Localization, Transportation, Utilities, Venture Capital & Private Equity, Veterinary, Warehousing, Wholesale, Wine & Spirits, Writing & Editing, Other, field ID: fldfTT4tCiqlccxnP, readonly field: false']
    status singleSelect [note: 'business desc: Status of a record; e.g., active, inactive, pending., technical desc: Type: singleSelect, Options: Active, Inactive, field ID: fldAw21Uz40Wz6SNg, readonly field: false']
    id autoNumber [note: 'business desc: Unique identifier., technical desc: Type: autoNumber, field ID: fld6DwWfSijqwBcEO, readonly field: true']
    note: '### advertisers Table (airtable id: tblchWDOuPzJczwMZ) - This table stores information about clients submitting campaign briefs, including their contact details and organizational context. It serves as a master registry to link client identity with submitted and approved campaign records across the CRM system.'
}

Table project_brief {
    project_brief_id formula [note: 'business desc: Unique identifier for each project brief, (autonumber + company name + created date) ., technical desc: Type: formula, field ID: fldd8EhKwRISulQMO, readonly field: true']
