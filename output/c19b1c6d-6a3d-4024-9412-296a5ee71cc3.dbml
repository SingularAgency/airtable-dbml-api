    record_id formula [note: 'business desc: System-generated unique identifier used for referencing this record across the platform and integrations., technical desc: Type: formula, field ID: fldb37QIeICev3hBy, readonly field: true']
    company_name multilineText [note: 'business desc: Company name associated with the campaign., technical desc: Type: multilineText, field ID: fldOdcfdsDixT6anD, readonly field: false']
