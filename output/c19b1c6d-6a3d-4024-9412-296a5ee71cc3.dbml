    PII_sensitivity_level singleSelect [note: 'business desc: Classifies the sensitivity level of personal data fields according to GDPR standards., technical desc: Type: singleSelect, Options: Non-Sensitive, Sensitive, Confidential, Highly Confidential, field ID: fld0iQrYXwMPGqlLU, readonly field: false']
