    Attachment_Summary aiText [note: 'business desc: An AI generated summary of the Attachments field. Upload files to Attachments to generate a summary., technical desc: Type: aiText, field ID: fldFtvxbqVS97WT4n, readonly field: false']
    rfps multipleRecordLinks [note: 'business desc: Links proposals to projects, enabling efficient tracking and management of business opportunities., technical desc: Type: multipleRecordLinks, Reference to rfps table, field ID: fldtHm7F1ffW1FHxD, readonly field: false']
    Status__from_rfps multipleLookupValues [note: 'business desc: Indicates the current status of requests for proposals (RFPs) in the workflow process., technical desc: Type: multipleLookupValues, field ID: fldLlw0kXs204svKd, readonly field: true']
    opportunity_url__from_rfps multipleLookupValues [note: 'business desc: Stores URLs linking to RFP opportunities for easy access and reference., technical desc: Type: multipleLookupValues, field ID: fld7ma5acF7B2fTZn, readonly field: true']
    rfp_base_url__from_rfps multipleLookupValues [note: 'business desc: Stores the base URL for RFP documents, linking to relevant resources and information., technical desc: Type: multipleLookupValues, field ID: fld4oI3J6meqxFtZW, readonly field: true']
    estimated_value__from_rfps multipleLookupValues [note: 'business desc: Represents the projected monetary value of proposals from requests for proposals (RFPs)., technical desc: Type: multipleLookupValues, field ID: fld3rVzosSsAHHuZ6, readonly field: true']
    decision_timestamp__from_rfps multipleLookupValues [note: 'business desc: Stores the date and time when a decision was made on a request for proposal (RFP)., technical desc: Type: multipleLookupValues, field ID: fldYx504BvCtRJDK3, readonly field: true']
    deadline__from_rfps multipleLookupValues [note: 'business desc: Stores the due date for responses to Requests for Proposals (RFPs)., technical desc: Type: multipleLookupValues, field ID: fld9jWfkOCT51VWRd, readonly field: true']
    id autoNumber [note: 'business desc: The id field uniquely identifies each record in the database for efficient data management., technical desc: Type: autoNumber, field ID: fldbJ028mq5uIeRvz, readonly field: true']
    record_id formula [note: 'business desc: Unique identifier for each record in the database, ensuring data integrity and retrieval., technical desc: Type: formula, field ID: fldB2PYINHBkYxiiy, readonly field: true']
    note: '### sales_prep Table (airtable id: tblTdsdmU6AEMDI2w) - The sales_prep table stores data related to sales preparation activities, including lead information, sales strategies, and performance metrics, aiding in optimizing sales processes.'
}

Table rfps {
    title singleLineText [note: 'business desc: Short descriptive title of the RFP opportunity., technical desc: Type: singleLineText, field ID: fldbhH9Ht8MBodZ3L, readonly field: false']
    status singleSelect [note: 'business desc: Current pursuit decision for this RFP., technical desc: Type: singleSelect, Options: Yes, No, Monitor, Needs_Clarification, Not answer, field ID: fldZE8C6lsxeHQy6c, readonly field: false']
    procurement_process singleSelect [note: 'business desc: procurement_process tracks the steps and status of acquiring goods or services in a business., technical desc: Type: singleSelect, Options: Pending, In process, Finished, field ID: fldTxGlv4PBtERB11, readonly field: false']
    notify singleSelect [note: 'business desc: Send a notification, technical desc: Type: singleSelect, Options: Pending, Email sent, field ID: fldRlquhZaNjIakBw, readonly field: false']
