    deadline__from_rfps__from_sales_rep multipleLookupValues [note: 'business desc: Stores the deadline for RFPs submitted by sales representatives., technical desc: Type: multipleLookupValues, field ID: fldQnN27q8U3H10xT, readonly field: true']
    opportunity_url url [note: 'business desc: External link to the official solicitation or bid portal., technical desc: Type: url, field ID: fld6nP7I9Zpj7Psi4, readonly field: false']
    rfp_base multipleAttachments [note: 'business desc: Link to the generated base RFP document or template., technical desc: Type: multipleAttachments, field ID: fldoUfdNOKvKlI6Ww, readonly field: false']
    rfp_info_extract aiText [note: 'business desc: Generates a customized RFP document based on the RFP base, sales representative name, primary contact name, and deadline., technical desc: Type: aiText, field ID: fldg2S1jRAimCTSCL, readonly field: false']
    estimated_value currency [note: 'business desc: Estimated contract value if awarded., technical desc: Type: currency, Precision: 2, Symbol: $, field ID: fldqrWFM2co64NIUE, readonly field: false']
    decision_timestamp createdTime [note: 'business desc: Records the date and time a decision was made for tracking and analysis., technical desc: Type: createdTime, field ID: flddDB5r2L77wECWg, readonly field: true']
    deadline date [note: 'business desc: Submission deadline date for the RFP., technical desc: Type: date, Format: M/D/YYYY, field ID: fldXYhcEkk1oYOsWJ, readonly field: false']
    internal_notes multilineText [note: 'business desc: Additional context, strategy, or risk flags related to this RFP., technical desc: Type: multilineText, field ID: fldESVs975fUP6346, readonly field: false']
    risk_flags aiText [note: 'business desc: Generates risk flags related to the RFP based on the internal notes., technical desc: Type: aiText, field ID: fldEEn4FYcLkx5gLu, readonly field: false']
    record_id formula [note: 'business desc: Unique identifier for each record in the database, ensuring data integrity and retrieval., technical desc: Type: formula, field ID: fldSSWtEuACvWcncC, readonly field: true']
    Attachments multipleAttachments [note: 'business desc: Attachments stores files or documents linked to records for reference or additional information., technical desc: Type: multipleAttachments, field ID: fldUlccvKD57jETN7, readonly field: false']
    Attachment_Summary aiText [note: 'business desc: An AI generated summary of the Attachments field. Upload files to Attachments to generate a summary., technical desc: Type: aiText, field ID: fld2F9EGku383x1sT, readonly field: false']
    note: '### rfps Table (airtable id: tblwFTawNSJitdQtj) - The rfps table stores Request for Proposal (RFP) data, including project details, vendor submissions, and evaluation criteria, facilitating procurement and vendor selection processes.'
}

