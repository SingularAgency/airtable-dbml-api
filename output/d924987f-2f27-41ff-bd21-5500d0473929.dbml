    sales_rep_name__from_sales_rep multipleLookupValues [note: 'business desc: Stores the name of the sales representative handling a specific sale., technical desc: Type: multipleLookupValues, field ID: fld1EJRHHEhxbAXYM, readonly field: true']
    primary_contact_name__from_sales_rep multipleLookupValues [note: 'business desc: Stores the name of the main contact person for a sales representative., technical desc: Type: multipleLookupValues, field ID: fldzGzcsE6Pmd1NG8, readonly field: true']
