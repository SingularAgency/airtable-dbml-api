    suggested_improvements aiText [note: 'business desc: suggested improvements information., technical desc: Type: aiText, field ID: fldAOOWEYvgBvSNEK, readonly field: false']
    Style_DNA multilineText [note: 'business desc: Style DNA information., technical desc: Type: multilineText, field ID: fldMRId1rk4HLDGOX, readonly field: false']
